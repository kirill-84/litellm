# Скопируйте в .env и подставьте реальные значения.
# (.env читается docker compose для ${...}-подстановки и прокидывается в контейнер litellm.)

# --- LiteLLM proxy ---
# master_key ДОЛЖЕН начинаться с sk-. Это же значение укажите в continue/config.yaml -> apiKey.
LITELLM_MASTER_KEY=sk-change-me

# --- Postgres ---
# Эти значения использует и сервис db, и строка DATABASE_URL ниже — держите их согласованными.
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=litellm

# Должно указывать на сервис db с теми же кредами, что и выше.
DATABASE_URL=postgresql://litellm:change-me@db:5432/litellm

# --- Ollama ---
# Адрес Ollama задаётся НЕ здесь, а в config.yaml -> litellm_params.api_base
# (замените там remote_ip на адрес/IP машины с Ollama).
